{
  "name": "plaasmark-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3002",
    "build": "node scripts/generate-pwa-icons.mjs && next build",
    "start": "next start -p 3002",
    "lint": "eslint .",
    "format": "prettier --write --ignore-unknown .",
    "format:check": "prettier --check --ignore-unknown .",
    "icons": "node scripts/generate-pwa-icons.mjs",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "prisma db seed",
    "db:seed:malmesbury": "node scripts/seed-malmesbury-extra.mjs",
    "db:snapshot": "node scripts/export-seed-snapshot.mjs",
    "db:setup": "prisma generate && prisma db seed",
    "db:setup:migrate": "prisma migrate deploy && prisma db seed",
    "postinstall": "prisma generate",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs}": [
      "eslint --fix --max-warnings 0",
      "prettier --write --ignore-unknown"
    ],
    "*.{json,md,css,yml,yaml}": "prettier --write --ignore-unknown"
  },
  "dependencies": {
    "@prisma/client": "^6.19.0",
    "bcryptjs": "^3.0.3",
    "html2canvas": "^1.4.1",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.11.0",
    "next": "16.2.4",
    "nodemailer": "^8.0.7",
    "qrcode.react": "^4.2.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-leaflet": "^5.0.0",
    "recharts": "^3.8.1",
    "styled-components": "^6.4.1",
    "ua-parser-js": "^2.0.9"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "prettier": "^3.6.2",
    "prisma": "^6.19.0",
    "sharp": "^0.34.5",
    "typescript": "^5"
  }
}
