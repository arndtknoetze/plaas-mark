generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Member {
  id        String   @id @default(cuid())
  name      String
  phone     String   @unique
  createdAt DateTime @default(now())

  stores Store[]
  orders Order[]
}

model Location {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())

  stores Store[]
  orders Order[]
}

model Store {
  id          String   @id @default(cuid())
  memberId    String
  member      Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  locationId  String
  location    Location @relation(fields: [locationId], references: [id])

  name        String
  slug        String
  isActive    Boolean  @default(false)
  brandColor  String   @default("#2E5E3E")
  logoUrl     String?  @db.LongText

  addressText String?
  email       String?
  whatsapp    String?
  instagram   String?
  facebook    String?
  website     String?
  hoursText   String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([memberId])
  @@index([locationId])
  @@unique([memberId, slug])
  @@index([slug])

  products Product[]
}

model Product {
  id         String   @id @default(cuid())
  title      String
  price      Decimal  @db.Decimal(10, 2)
  unit       String?
  vendorId   String
  vendorName String   @default("")
  image      String?  @db.LongText
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  store Store @relation(fields: [vendorId], references: [id], onDelete: Cascade)
}

model Order {
  id          String      @id @default(cuid())
  memberId    String
  member      Member      @relation(fields: [memberId], references: [id], onDelete: Cascade)
  locationId  String
  location    Location    @relation(fields: [locationId], references: [id])
  notes       String?
  createdAt   DateTime    @default(now())
  items       OrderItem[]

  @@index([memberId])
  @@index([locationId])
}

model OrderItem {
  id          String   @id @default(cuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String
  name        String
  price       Decimal  @db.Decimal(10, 2)
  quantity    Int
  vendorId    String   @default("")
  vendorName  String   @default("")

  @@index([orderId])
}

/// Short-lived 6-digit challenge; replaced on each new request for the same phone.
model PhoneOtpChallenge {
  id        String   @id @default(cuid())
  phone     String
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([phone])
}

/// Issued after correct OTP; required to place an order for that phone (single use).
model PhoneVerifyToken {
  id        String   @id @default(cuid())
  token     String   @unique
  phone     String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([phone])
}

/// Fixed-window counters for API rate limits (e.g. POST /api/orders per IP).
model RateLimitBucket {
  id        String   @id @default(cuid())
  scope     String
  bucketKey String
  windowId  String
  count     Int      @default(0)
  expiresAt DateTime

  @@unique([scope, bucketKey, windowId])
  @@index([expiresAt])
}
