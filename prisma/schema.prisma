generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Member {
  id        String   @id @default(cuid())
  name      String
  phone     String   @unique
  createdAt DateTime @default(now())

  stores        Store[]
  orders        Order[]
  notifications Notification[]
}

model Notification {
  id        String   @id @default(cuid())
  memberId  String
  member    Member   @relation(fields: [memberId], references: [id])
  type      String
  title     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([memberId])
}

model Location {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())

  stores Store[]
  orders Order[]
}

model Store {
  id          String   @id @default(cuid())
  memberId    String
  member      Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  locationId  String
  location    Location @relation(fields: [locationId], references: [id])

  name        String
  slug        String
  isActive    Boolean  @default(true)
  brandColor  String   @default("#2E5E3E")
  logoUrl     String?  @db.LongText

  addressText String?
  email       String?
  whatsapp    String?
  instagram   String?
  facebook    String?
  website     String?
  hoursText   String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([memberId])
  @@index([locationId])
  @@unique([memberId, slug])
  @@index([slug])

  products Product[]
}

model Product {
  id         String   @id @default(cuid())
  title      String
  price      Decimal  @db.Decimal(10, 2)
  unit       String?
  vendorId   String
  vendorName String   @default("")
  image      String?  @db.LongText
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  store Store @relation(fields: [vendorId], references: [id], onDelete: Cascade)
}

model Order {
  id          String      @id @default(cuid())
  memberId    String
  member      Member      @relation(fields: [memberId], references: [id], onDelete: Cascade)
  locationId  String
  location    Location    @relation(fields: [locationId], references: [id])
  /// pending | accepted | ready | completed
  status      String      @default("pending")
  notes       String?
  createdAt   DateTime    @default(now())
  items       OrderItem[]

  @@index([memberId])
  @@index([locationId])
}

model OrderItem {
  id          String   @id @default(cuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String
  name        String
  price       Decimal  @db.Decimal(10, 2)
  quantity    Int
  vendorId    String   @default("")
  vendorName  String   @default("")

  @@index([orderId])
}

/// Short-lived 6-digit challenge; replaced on each new request for the same phone.
model PhoneOtpChallenge {
  id        String   @id @default(cuid())
  phone     String
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([phone])
}

/// Issued after correct OTP; required to place an order for that phone (single use).
model PhoneVerifyToken {
  id        String   @id @default(cuid())
  token     String   @unique
  phone     String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([phone])
}

/// Fixed-window counters for API rate limits (e.g. POST /api/orders per IP).
model RateLimitBucket {
  id        String   @id @default(cuid())
  scope     String
  bucketKey String
  windowId  String
  count     Int      @default(0)
  expiresAt DateTime

  @@unique([scope, bucketKey, windowId])
  @@index([expiresAt])
}

/// Anonymous (or member-linked) first-party analytics session keyed by a cookie id.
model AnalyticsSession {
  id           String   @id @default(cuid())
  anonId       String   @unique
  memberId     String?
  member       Member?  @relation(fields: [memberId], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())
  lastSeenAt   DateTime @default(now())

  events AnalyticsEvent[]

  @@index([memberId])
  @@index([lastSeenAt])
}

/// Raw event stream for product analytics (page views, funnel steps, etc.).
model AnalyticsEvent {
  id          String           @id @default(cuid())
  sessionId   String
  session     AnalyticsSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  type        String
  path        String
  referrer    String?
  locale      String?

  locationId  String?
  location    Location?        @relation(fields: [locationId], references: [id], onDelete: SetNull)
  storeId     String?
  store       Store?           @relation(fields: [storeId], references: [id], onDelete: SetNull)
  orderId     String?
  order       Order?           @relation(fields: [orderId], references: [id], onDelete: SetNull)

  ipHash      String?
  userAgent   String?          @db.Text
  props       Json?
  createdAt   DateTime         @default(now())

  @@index([sessionId, createdAt])
  @@index([type, createdAt])
  @@index([locationId, createdAt])
  @@index([storeId, createdAt])
  @@index([orderId])
}
