PORT=3002

# PostgreSQL (verstek vir Prisma). Geen wagwoord: los :password tussen // en @ uit.
# Gebruiker is dikwels postgres, of jou macOS-gebruikersnaam vir plaaslike Postgres.
DATABASE_URL="postgresql://postgres@localhost:5432/plaas-mark"

# MySQL: stel datasource provider in prisma/schema.prisma op "mysql", dan bv.:
# DATABASE_URL="mysql://root@localhost:3306/plaas-mark"
