PORT=3002

# Dev only: API returns `devCode` in POST /api/verify-phone/request so you can test without SMS. Never set in production.
# VERIFICATION_OTP_IN_RESPONSE=true

# Dev only: enables /admin/orders (no auth). Never set in production.
# ADMIN_ROUTES_ENABLED=true

# MySQL (Prisma datasource is mysql). Geen wagwoord: los :password tussen // en @ uit.
DATABASE_URL="mysql://root@localhost:3306/plaas-mark"

# PostgreSQL: stel prisma/schema.prisma datasource terug na "postgresql" en gebruik bv.:
# DATABASE_URL="postgresql://postgres@localhost:5432/plaas-mark"
